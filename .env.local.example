# Copy to .env.local and fill in real values. Every server-side variable here
# is required at boot (lib/env.server.ts throws on missing/empty values).
# Never commit .env.local.

# Postgres connection string. Use the Supabase POOLER string (IPv4-reachable,
# host like aws-0-<region>.pooler.supabase.com:6543), not the direct host,
# which is IPv6-only. See RUNBOOK.md "Provisioning the database".
DATABASE_URL=postgresql://user:password@host:6543/postgres

# Etherscan v2 API key (EVM tx history). https://etherscan.io/apis
ETHERSCAN_API_KEY=your-etherscan-key

# Alchemy API key (EVM transfers fallback, ENS). https://dashboard.alchemy.com
ALCHEMY_API_KEY=your-alchemy-key

# The Graph gateway key (lending-protocol borrow/liquidation detection).
# https://thegraph.com/studio/apikeys/
THEGRAPH_API_KEY=your-thegraph-key

# Helius API key (Solana RPC). Server-only: the client reaches Solana through
# /api/solana-rpc. Never expose this as NEXT_PUBLIC_*.
HELIUS_API_KEY=your-helius-key

# --- Optional client-side variables (inlined into the browser bundle) ---

# Absolute origin used for OG image URLs and share links.
# NEXT_PUBLIC_APP_URL=https://chainscore.dev

# WalletConnect Cloud project id for EVM wallet connect.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# --- Autopilot agent layer (all optional; agents stay off without them) ---

# Model access for agent runs.
# ANTHROPIC_API_KEY=your-anthropic-key

# Marketing channels (server-side only, never NEXT_PUBLIC_).
# RESEND_API_KEY=your-resend-key
# NEYNAR_API_KEY=your-neynar-key
# X_API_KEY= / X_API_SECRET= / X_ACCESS_TOKEN= / X_ACCESS_SECRET=

# Kill switch: 'true' halts every agent.
# AGENTS_KILL_SWITCH=false

# Orchestrator cron auth (Vercel Cron sends Authorization: Bearer <this>).
# CRON_SECRET=generate-a-long-random-string

# Owner token for /admin/autopilot. Absent = the whole /admin surface 404s.
# ADMIN_DASH_TOKEN=generate-a-long-random-string

# Nightly digest recipient (requires RESEND_API_KEY).
# DIGEST_EMAIL=you@example.com

# Per-agent enable flags (default off).
# AGENT_STRATEGY_ENABLED=false
# AGENT_ENGINEERING_ENABLED=false
# AGENT_MARKETING_ENABLED=false

# Spend caps in USD/day (G2 backstop). Zero = no spend possible.
# SPEND_CAP_DAILY_USD=0
# SPEND_CAP_CHANNEL_DAILY_USD=0

# --- Optional server-side flags ---

# 'true' enables cross-source ingest reconciliation logging (doubles provider
# load on sampled reads; leave off in production until budgets are sized).
# INGEST_RECONCILE=true
