{
  "name": "chainscore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && node scripts/check-client-secrets.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:client-secrets": "node scripts/check-client-secrets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:ci": "vitest run && playwright test",
    "backtest": "tsx scripts/runBacktest.ts",
    "loadtest": "tsx scripts/loadTest.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-progress": "^1.1.8",
