generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Wallet {
  address          String            @id
  chain            String            @default("EVM")
  ens              String?
  score            Int
  grade            String
  percentile       Float
  lastUpdated      DateTime          @updatedAt
  scoreHistory     ScoreSnapshot[]
  listingsAsLender LoanListing[]     @relation("LenderListings")
  loansAsBorrower  Loan[]            @relation("BorrowerLoans")
  loansAsLender    Loan[]            @relation("LenderLoans")
  reviewsGiven     Review[]          @relation("ReviewsGiven")
  reviewsReceived  Review[]          @relation("ReviewsReceived")
  applications     LoanApplication[]
}

model ScoreSnapshot {
  id            String   @id @default(cuid())
  walletAddress String
  score         Int
  timestamp     DateTime @default(now())
  wallet        Wallet   @relation(fields: [walletAddress], references: [address])
}

model LoanListing {
  id                 String            @id @default(cuid())
  lenderAddress      String
  lenderScore        Int
  amount             Float
  currency           String
  minAPR             Float
  maxAPR             Float
  durationDays       Int
  minBorrowerScore   Int
  collateralRequired Float
  chain              String            @default("EVM")
  status             ListingStatus     @default(OPEN)
  createdAt          DateTime          @default(now())
  expiresAt          DateTime
  terms              String
  lender             Wallet            @relation("LenderListings", fields: [lenderAddress], references: [address])
  applications       LoanApplication[]
  loan               Loan?
}

model LoanApplication {
  id              String            @id @default(cuid())
  listingId       String
  borrowerAddress String
  borrowerScore   Int
  requestedAmount Float
  message         String?
  status          ApplicationStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  listing         LoanListing       @relation(fields: [listingId], references: [id])
  borrower        Wallet            @relation(fields: [borrowerAddress], references: [address])
  loan            Loan?
}

model Loan {
  id                 String          @id @default(cuid())
  listingId          String          @unique
  applicationId      String          @unique
  lenderAddress      String
  borrowerAddress    String
  amount             Float
  currency           String
  APR                Float
  collateralAmount   Float
  collateralCurrency String
  feeAmount          Float           @default(0)
  startDate          DateTime        @default(now())
  dueDate            DateTime
  status             LoanStatus      @default(ACTIVE)
  txHash             String?
  repaidAt           DateTime?
  repaidTxHash       String?
  listing            LoanListing     @relation(fields: [listingId], references: [id])
  application        LoanApplication @relation(fields: [applicationId], references: [id])
  lender             Wallet          @relation("LenderLoans", fields: [lenderAddress], references: [address])
  borrower           Wallet          @relation("BorrowerLoans", fields: [borrowerAddress], references: [address])
  reviews            Review[]
}

model Review {
  id              String   @id @default(cuid())
  loanId          String
  reviewerAddress String
  revieweeAddress String
  rating          Int
  comment         String?
  createdAt       DateTime @default(now())
  loan            Loan     @relation(fields: [loanId], references: [id])
  reviewer        Wallet   @relation("ReviewsGiven", fields: [reviewerAddress], references: [address])
  reviewee        Wallet   @relation("ReviewsReceived", fields: [revieweeAddress], references: [address])
}

// Point-in-time feature store (Workstream C). Every row is stamped with the
// moment its data was valid; nothing may ever be read for an as_of earlier
// than validAtTs. Scores logged against a snapshot are reproducible:
// (features, featureSetVersion, modelVersion) fully determine the score.
model FeatureSnapshot {
  id                String   @id @default(cuid())
  address           String
  chain             String
  // Unix seconds; the newest data observable inside this vector.
  validAtTs         Int
  featureSetVersion String
  // Ordered feature vector in ml/feature_schema.json order.
  features          Json
  dataCompleteness  Float    @default(1)
  createdAt         DateTime @default(now())

  @@unique([address, chain, validAtTs, featureSetVersion])
  @@index([address, chain])
}

// Realized outcomes per (wallet, chain) for a documented criteria version.
// See LABELS.md; criteriaVersion changes whenever the definition does.
model OutcomeLabel {
  id              String   @id @default(cuid())
  address         String
  chain           String
  // Outcome window [windowStartTs, windowEndTs), unix seconds.
  windowStartTs   Int
  windowEndTs     Int
  label           Int
  criteriaVersion String
  createdAt       DateTime @default(now())

  @@unique([address, chain, windowStartTs, criteriaVersion])
  @@index([address, chain])
}

// One row per reproducible backtest run; the artifact lives in
// reports/backtest/ and metrics are denormalized here for querying.
model BacktestRun {
  id                String   @id @default(cuid())
  modelVersion      String
  featureSetVersion String
  criteriaVersion   String
  nRows             Int
  rocAuc            Float
  prAuc             Float
  brier             Float
  reportPath        String
  createdAt         DateTime @default(now())
}

// Partner API keys (Workstream E). Only the SHA-256 hash is stored; the
// plaintext is shown once at creation and never persisted.
model ApiKey {
  id              String                @id
  name            String
  keyHash         String                @unique
  rateLimitPerMin Int                   @default(60)
  createdAt       DateTime              @default(now())
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  webhooks        WebhookSubscription[]
}

// Score-change webhook subscriptions (Workstream E).
model WebhookSubscription {
  id        String    @id @default(cuid())
  apiKeyId  String
  address   String
  chain     String
  url       String
  secret    String
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  apiKey    ApiKey    @relation(fields: [apiKeyId], references: [id])

  @@index([address, chain])
}

// Resolved entity clusters (Workstream D). A cluster groups addresses judged
// to be one actor above the merge confidence threshold. Merges are reversible:
// reversedAt plus the retained links and cohesion are the audit trail, so a
// wrong merge can be undone and explained.
model Entity {
  id          String             @id @default(cuid())
  cohesion    Float
  memberCount Int
  createdAt   DateTime           @default(now())
  reversedAt  DateTime?
  reversedBy  String?
  members     EntityMembership[]
  audits      MergeAudit[]
}

model EntityMembership {
  id         String    @id @default(cuid())
  entityId   String
  address    String
  chain      String
  // Confidence with which this address was attached to the entity.
  confidence Float
  addedAt    DateTime  @default(now())
  removedAt  DateTime?
  entity     Entity    @relation(fields: [entityId], references: [id])

  @@unique([entityId, address, chain])
  @@index([address])
}

// Append-only log of every merge and reversal, with the signals that drove
// the decision, so any entity association is explainable after the fact.
model MergeAudit {
  id         String   @id @default(cuid())
  entityId   String
  action     String // 'merge' | 'reverse'
  addressA   String
  addressB   String
  confidence Float
  signals    Json
  createdAt  DateTime @default(now())
  entity     Entity   @relation(fields: [entityId], references: [id])
}

// Server-issued, single-use, expiring nonces for authenticated write actions.
// A signature is only accepted over a message the server itself issued and
// bound to (address, action), which closes the replay hole where any captured
// signature authorized any action forever.
model AuthNonce {
  id        String    @id @default(cuid())
  address   String
  action    String
  message   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([address])
}

model Notification {
  id        String   @id @default(cuid())
  address   String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

enum ListingStatus {
  OPEN
  MATCHED
  ACTIVE
  COMPLETED
  DEFAULTED
  EXPIRED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum LoanStatus {
  ACTIVE
  REPAID
  DEFAULTED
  LIQUIDATED
}

// ---- Autopilot: Facts Registry (G3) ----
// The single source of truth for every metric ChainScore may state publicly.
// The website and the marketing agent may only surface metrics that exist
// here with verified = true; the pre-publish validator (lib/facts) enforces
// it. value is the display form ("300 to 850", "7,720"); numericValue is the
// machine-comparable magnitude the validator matches numbers against (null
// for non-scalar facts like ranges, which use the aliases field instead).
model FactsRegistry {
  key          String   @id
  value        String
  numericValue Float?
  unit         String?
  definition   String
  source       String
  asOf         DateTime
  verified     Boolean  @default(false)
  updatedBy    String
  updatedAt    DateTime @updatedAt

  @@map("facts_registry")
}

// ---- Autopilot: shared agent-platform state (Phase 1) ----

enum AgentTaskStatus {
  QUEUED
  IN_PROGRESS
  DONE
  BLOCKED
  CANCELLED
}

enum AgentRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  HALTED
}

enum OutboxStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

enum OutboxKind {
  SPEND
  MERGE
  DEPLOY
  CONFIG
  OTHER
}

enum ContentStatus {
  IDEA
  GENERATED
  POSTED
  BLOCKED
  FAILED
}

model Goal {
  id          String   @id @default(cuid())
  title       String
  description String
  rationale   String
  status      String   @default("proposed")
  quarter     String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("goals")
}

model Kpi {
  id         String    @id @default(cuid())
  key        String    @unique
  name       String
  definition String
  current    Float?
  target     Float?
  unit       String?
  asOf       DateTime?
  updatedBy  String
  updatedAt  DateTime  @updatedAt

  @@map("kpis")
}

model Sprint {
  id       String      @id @default(cuid())
  name     String
  focus    String
  status   String      @default("proposed")
  startsAt DateTime
  endsAt   DateTime
  tasks    AgentTask[]

  @@map("sprints")
}

model AgentTask {
  id          String          @id @default(cuid())
  title       String
  description String
  agent       String
  status      AgentTaskStatus @default(QUEUED)
  priority    Int             @default(3)
  sprintId    String?
  sprint      Sprint?         @relation(fields: [sprintId], references: [id])
  result      String?
  createdBy   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status, priority])
  @@map("agent_tasks")
}

model DecisionLog {
  id        String   @id @default(cuid())
  actor     String
  summary   String
  detail    String?
  createdAt DateTime @default(now())

  @@map("decision_log")
}

model AgentRun {
  id           String         @id @default(cuid())
  agent        String
  trigger      String
  status       AgentRunStatus @default(RUNNING)
  model        String?
  inputTokens  Int?
  outputTokens Int?
  costUsd      Float          @default(0)
  summary      String?
  error        String?
  startedAt    DateTime       @default(now())
  finishedAt   DateTime?
  actions      AgentAction[]

  @@index([agent, startedAt])
  @@map("agent_runs")
}

model AgentAction {
  id         String   @id @default(cuid())
  runId      String
  run        AgentRun @relation(fields: [runId], references: [id])
  tool       String
  inputJson  String
  outputJson String?
  status     String   @default("executed")
  costUsd    Float    @default(0)
  createdAt  DateTime @default(now())

  @@index([runId])
  @@map("agent_actions")
}

model OutboxItem {
  id          String       @id @default(cuid())
  kind        OutboxKind
  title       String
  payloadJson String
  proposedBy  String
  runId       String?
  amountUsd   Float?
  channel     String?
  status      OutboxStatus @default(PENDING)
  decidedBy   String?
  decidedAt   DateTime?
  executedAt  DateTime?
  resultJson  String?
  note        String?
  createdAt   DateTime     @default(now())

  @@index([status, createdAt])
  @@map("outbox")
}

model ContentItem {
  id          String        @id @default(cuid())
  channel     String
  status      ContentStatus @default(IDEA)
  title       String?
  body        String
  factKeys    String?
  utm         String?
  externalId  String?
  metricsJson String?
  postedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([channel, status])
  @@map("content_items")
}

// ---- Pricing: plans are code config (lib/pricing/plans.ts); these tables
// hold who is on what plan and what they used ----

model Subscription {
  id            String   @id @default(cuid())
  apiKeyId      String   @unique
  planId        String   @default("free")
  overageCapUsd Float    @default(50)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("subscriptions")
}

model UsageRecord {
  id         String   @id @default(cuid())
  apiKeyId   String
  period     String
  scores     Int      @default(0)
  overageUsd Float    @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([apiKeyId, period])
  @@map("usage_records")
}
